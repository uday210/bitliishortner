{
  "manifest_version": 3,
  "name": "Snip — URL Shortener",
  "version": "1.0.0",
  "description": "Shorten any URL instantly with Snip (bitil.io)",
  "permissions": ["activeTab", "contextMenus", "storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
