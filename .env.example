# Supabase connection pooler URL (use this for Railway/production)
# Get from: Supabase Dashboard → Settings → Database → Connection Pooling
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Random secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET="your-random-secret-here"

# Login credentials
AUTH_USERNAME="your@email.com"
AUTH_PASSWORD="yourpassword"
